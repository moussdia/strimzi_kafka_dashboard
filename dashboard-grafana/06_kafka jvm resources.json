{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "datasource", "uid": "grafana" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "JVM & Resources - Heap, GC, CPU, Threads, File Descriptors (Kafka + ZooKeeper pods)",
  "editable": true, "fiscalYearStartMonth": 0, "graphTooltip": 1, "id": null, "links": [],
  "panels": [
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "☕ JVM Heap", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "% utilisation heap JVM par pod Kafka - alerte > 80%, critique > 95%",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "min": 0, "max": 1, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.80 }, { "color": "red", "value": 0.95 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 }, "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "showThresholdLabels": true, "showThresholdMarkers": true },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_used_bytes{area=\"heap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name) / sum(jvm_memory_max_bytes{area=\"heap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "{{kubernetes_pod_name}}", "refId": "A" }],
      "title": "Heap JVM Kafka (%)", "type": "gauge"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Utilisation heap JVM dans le temps - Kafka et ZooKeeper",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 }, "id": 3,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_used_bytes{area=\"heap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Kafka - {{kubernetes_pod_name}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_max_bytes{area=\"heap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Heap Max - {{kubernetes_pod_name}}", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_used_bytes{area=\"heap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-zookeeper-.*\"}) by (kubernetes_pod_name)", "legendFormat": "ZK - {{kubernetes_pod_name}}", "refId": "C" }
      ],
      "title": "Heap JVM Used / Max (bytes)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Utilisation Metaspace (non-heap) par pod Kafka",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 }, "id": 4,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_used_bytes{area=\"nonheap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Metaspace Used - {{kubernetes_pod_name}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_committed_bytes{area=\"nonheap\", namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Metaspace Committed - {{kubernetes_pod_name}}", "refId": "B" }
      ],
      "title": "Non-Heap (Metaspace) Kafka (bytes)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Utilisation des memory pools JVM (Old Gen, Eden, Survivor)",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 5 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 }, "id": 5,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_memory_pool_bytes_used{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (pool)", "legendFormat": "{{pool}}", "refId": "A" }
      ],
      "title": "Memory Pools JVM Kafka", "type": "timeseries"
    },
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 10, "title": "🗑️ Garbage Collector", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Temps passé en GC par pod - critique si > 20% du temps CPU",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.10 }, { "color": "red", "value": 0.20 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 }, "id": 11,
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(jvm_gc_collection_seconds_sum{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}[5m])) by (kubernetes_pod_name)", "legendFormat": "GC Time Ratio - {{kubernetes_pod_name}}", "refId": "A" }],
      "title": "GC Time Ratio Kafka (%)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Fréquence des GC par pod Kafka",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 }, "id": 12,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(jvm_gc_collection_seconds_count{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}[5m])) by (kubernetes_pod_name, gc)", "legendFormat": "{{gc}} - {{kubernetes_pod_name}}", "refId": "A" }
      ],
      "title": "Fréquence GC Kafka (/s)", "type": "timeseries"
    },
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }, "id": 20, "title": "⚙️ CPU & Threads", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Utilisation CPU container Kafka et ZooKeeper (cAdvisor)",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "cores" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 }, "id": 21,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-kafka-.*\", container=\"kafka\"}[5m])) by (pod)", "legendFormat": "Kafka - {{pod}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-zookeeper-.*\", container=\"zookeeper\"}[5m])) by (pod)", "legendFormat": "ZK - {{pod}}", "refId": "B" }
      ],
      "title": "CPU Usage Kafka & ZooKeeper (cores)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "CPU throttling - si élevé, augmenter les CPU limits des pods",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.25 }, { "color": "red", "value": 0.50 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 }, "id": 22,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(container_cpu_cfs_throttled_seconds_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-kafka-.*\", container=\"kafka\"}[5m]) / rate(container_cpu_cfs_periods_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-kafka-.*\", container=\"kafka\"}[5m])", "legendFormat": "Throttle Kafka - {{pod}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "rate(container_cpu_cfs_throttled_seconds_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-zookeeper-.*\", container=\"zookeeper\"}[5m]) / rate(container_cpu_cfs_periods_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-zookeeper-.*\", container=\"zookeeper\"}[5m])", "legendFormat": "Throttle ZK - {{pod}}", "refId": "B" }
      ],
      "title": "CPU Throttling (%)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Threads JVM actifs, daemon, peak et deadlocked",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 }, "id": 23,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_threads_current{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Threads Current - {{kubernetes_pod_name}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_threads_daemon{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Threads Daemon - {{kubernetes_pod_name}}", "refId": "B" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(jvm_threads_peak{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "Threads Peak - {{kubernetes_pod_name}}", "refId": "C" }
      ],
      "title": "Threads JVM Kafka", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "File descriptors - alerte si > 80% du max (risque 'too many open files')",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.60 }, { "color": "red", "value": 0.80 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 }, "id": 24,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(process_open_fds{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name) / sum(process_max_fds{namespace=\"$kubernetes_namespace\", kubernetes_pod_name=~\"$strimzi_cluster_name-kafka-.*\"}) by (kubernetes_pod_name)", "legendFormat": "FD Usage % - {{kubernetes_pod_name}}", "refId": "A" }
      ],
      "title": "File Descriptors Usage (%)", "type": "timeseries"
    },
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 }, "id": 30, "title": "Mémoire Container", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Utilisation mémoire container Kafka et ZooKeeper",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 }, "id": 31,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(container_memory_working_set_bytes{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-kafka-.*\", container=\"kafka\"}) by (pod)", "legendFormat": "WSS Kafka - {{pod}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(container_memory_working_set_bytes{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-zookeeper-.*\", container=\"zookeeper\"}) by (pod)", "legendFormat": "WSS ZK - {{pod}}", "refId": "B" }
      ],
      "title": "Memory Working Set (bytes)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}",
      "description": "Redémarrages des pods Kafka et ZooKeeper - alerte si crashloop",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 }, "id": 32,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-kafka-.*\"}[15m])", "legendFormat": "Restarts Kafka - {{pod}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "increase(kube_pod_container_status_restarts_total{namespace=\"$kubernetes_namespace\", pod=~\"$strimzi_cluster_name-zookeeper-.*\"}[15m])", "legendFormat": "Restarts ZK - {{pod}}", "refId": "B" }
      ],
      "title": "Redémarrages Pods (15 min)", "type": "timeseries"
    }
  ],
  "refresh": "30s", "schemaVersion": 38,
  "tags": ["kafka", "strimzi", "jvm", "resources"],
  "templating": {
    "list": [
      { "current": {}, "datasource": "${DS_PROMETHEUS}", "definition": "label_values(jvm_memory_used_bytes, namespace)", "hide": 0, "label": "Namespace", "name": "kubernetes_namespace", "options": [], "query": "label_values(jvm_memory_used_bytes, namespace)", "refresh": 2, "sort": 1, "type": "query" },
      { "current": {}, "datasource": "${DS_PROMETHEUS}", "definition": "label_values(kafka_server_replicamanager_leadercount{namespace=\"$kubernetes_namespace\"}, strimzi_io_cluster)", "hide": 0, "label": "Cluster", "name": "strimzi_cluster_name", "options": [], "query": "label_values(kafka_server_replicamanager_leadercount{namespace=\"$kubernetes_namespace\"}, strimzi_io_cluster)", "refresh": 2, "sort": 1, "type": "query" }
    ]
  },
  "time": { "from": "now-1h", "to": "now" }, "timepicker": {}, "timezone": "browser",
  "title": "06_JVM & Resources",
  "uid": "kafka-jvm-resources-06", "version": 1
}