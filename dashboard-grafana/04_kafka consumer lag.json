{
  "__inputs": [{ "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus" }],
  "__requires": [
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "bargauge", "name": "Bar gauge", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [{ "builtIn": 1, "datasource": { "type": "datasource", "uid": "grafana" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" }] },
  "description": "Consumer Lag - Lag par consumer group, SLA, taux de consommation (Kafka Exporter)",
  "editable": true, "fiscalYearStartMonth": 0, "graphTooltip": 1, "id": null, "links": [],
  "panels": [
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 1, "title": "Lag Global", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Lag total du consumer group sélectionné (toutes partitions confondues)",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10000 }, { "color": "red", "value": 100000 }] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 }, "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",consumergroup=\"$consumergroup\",topic!~\"__.*\"})", "refId": "A" }],
      "title": "Lag Total - $consumergroup", "type": "stat"
    },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Top 5 consumer groups avec le plus de lag",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10000 }, { "color": "red", "value": 100000 }] }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 }, "id": 3,
      "options": { "displayMode": "lcd", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "topk(10, sum(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",topic!~\"__.*\"}) by (consumergroup))", "legendFormat": "{{consumergroup}}", "refId": "A" }],
      "title": "Top 10 Consumer Groups par Lag", "type": "bargauge"
    },
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 10, "title": "Évolution du Lag", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Évolution du lag dans le temps pour le consumer group sélectionné",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10000 }, { "color": "red", "value": 100000 }] }
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 }, "id": 11,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",consumergroup=\"$consumergroup\",topic!~\"__.*\"}) by (topic, partition)", "legendFormat": "{{topic}}/{{partition}}", "refId": "A" }
      ],
      "title": "Lag par Topic/Partition - $consumergroup", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Croissance du lag sur 10 minutes - si positif le consumer prend du retard",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "custom": { "lineWidth": 2 }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 100 }, { "color": "red", "value": 1000 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 }, "id": 12,
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",topic!~\"__.*\"}[10m])) by (consumergroup, topic)", "legendFormat": "{{consumergroup}} / {{topic}}", "refId": "A" }],
      "title": "Taux de Croissance du Lag (msg/s)", "type": "timeseries"
    },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Temps estimé en secondes pour résorber le lag",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 }, "id": 13,
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",consumergroup=\"$consumergroup\",topic!~\"__.*\"}) by (topic) / clamp_min(sum(rate(kafka_consumergroup_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",consumergroup=\"$consumergroup\",topic!~\"__.*\"}[5m])) by (topic), 0.001)", "legendFormat": "Time to recover - {{topic}}", "refId": "A" }],
      "title": "Temps Estimé Résorption Lag", "type": "timeseries"
    },
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 20, "title": "⚖️ Production vs Consommation", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Comparaison taux de production vs taux de consommation",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 }, "unit": "mps" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 }, "id": 21,
      "targets": [
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(kafka_topic_partition_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",topic=\"$topic\"}[5m])) by (topic)", "legendFormat": "Production - {{topic}}", "refId": "A" },
        { "datasource": "${DS_PROMETHEUS}", "expr": "sum(rate(kafka_consumergroup_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",consumergroup=\"$consumergroup\",topic=\"$topic\"}[5m])) by (topic)", "legendFormat": "Consommation - $consumergroup / {{topic}}", "refId": "B" }
      ],
      "title": "Taux Production vs Consommation (msg/s)", "type": "timeseries"
    },
    { "collapsed": false, "datasource": "${DS_PROMETHEUS}", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "id": 30, "title": "👥 Consumer Groups", "type": "row" },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Consumer groups sans membres actifs (processus mort ou suspendu)",
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "consumergroup" }, "properties": [{ "id": "displayName", "value": "Consumer Group" }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Membres" }, { "id": "custom.displayMode", "value": "color-background" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 }, "id": 31,
      "options": { "sortBy": [{ "displayName": "Membres", "desc": false }] },
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "kafka_consumergroup_members{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\"} == 0", "legendFormat": "{{consumergroup}}", "refId": "A", "instant": true, "format": "table" }],
      "title": "Consumer Groups Sans Membres", "type": "table"
    },
    {
      "datasource": "${DS_PROMETHEUS}", "description": "Lag des consumer groups internes Kafka (__consumer_offsets etc.)",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 }, "unit": "short" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 }, "id": 32,
      "targets": [{ "datasource": "${DS_PROMETHEUS}", "expr": "sum(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",consumergroup=~\"__.*\"}) by (consumergroup)", "legendFormat": "{{consumergroup}}", "refId": "A" }],
      "title": "Lag Consumer Groups Internes Kafka", "type": "timeseries"
    }
  ],
  "refresh": "30s", "schemaVersion": 38,
  "tags": ["kafka", "strimzi", "consumer-lag"],
  "templating": {
    "list": [
      { "current": {}, "datasource": "${DS_PROMETHEUS}", "definition": "label_values(kafka_consumergroup_lag, namespace)", "hide": 0, "label": "Namespace", "name": "kubernetes_namespace", "options": [], "query": "label_values(kafka_consumergroup_lag, namespace)", "refresh": 2, "sort": 1, "type": "query" },
      { "current": {}, "datasource": "${DS_PROMETHEUS}", "definition": "label_values(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\"}, strimzi_io_cluster)", "hide": 0, "label": "Cluster", "name": "strimzi_cluster_name", "options": [], "query": "label_values(kafka_consumergroup_lag{namespace=\"$kubernetes_namespace\"}, strimzi_io_cluster)", "refresh": 2, "sort": 1, "type": "query" },
      { "current": {}, "datasource": "${DS_PROMETHEUS}", "definition": "label_values(kafka_consumergroup_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\"}, consumergroup)", "hide": 0, "includeAll": false, "label": "Consumer Group", "name": "consumergroup", "options": [], "query": "label_values(kafka_consumergroup_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\"}, consumergroup)", "refresh": 2, "sort": 1, "type": "query" },
      { "current": {}, "datasource": "${DS_PROMETHEUS}", "definition": "label_values(kafka_topic_partition_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",topic!~\"__.*\"}, topic)", "hide": 0, "includeAll": true, "label": "Topic", "name": "topic", "options": [], "query": "label_values(kafka_topic_partition_current_offset{namespace=\"$kubernetes_namespace\",strimzi_io_cluster=\"$strimzi_cluster_name\",topic!~\"__.*\"}, topic)", "refresh": 2, "sort": 1, "type": "query" }
    ]
  },
  "time": { "from": "now-1h", "to": "now" }, "timepicker": {}, "timezone": "browser",
  "title": "04 - Kafka Consumer Lag",
  "uid": "kafka-consumer-lag-04", "version": 1
}